# P1 Horizon — Data Collection Environment Variables
# Copy this file to .env and fill in values as needed

# Optional: Government API credentials (if required)
# VISA_BULLETIN_API_KEY=your_key_here
# DOL_API_KEY=your_key_here

# Data Storage
# LOCAL_DATA_PATH=/path/to/data/storage
# (defaults to ./downloads/)

# Logging
# LOG_LEVEL=INFO
# (options: DEBUG, INFO, WARNING, ERROR)

# Network (optional)
# PROXY_URL=http://proxy.example.com:8080
# TIMEOUT_SECONDS=30

# For corporate networks (if applicable)
# NETWORK_INTERFACE=eth0
# USE_VPN=true
